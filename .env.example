# Copy to .env and adjust as needed:  cp .env.example .env

# ---------- PostgreSQL ----------
POSTGRES_DB=whatsapp
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Kafka ----------
# Host-facing port for tooling (kcat etc.). Internal services use kafka:9092.
KAFKA_EXTERNAL_PORT=9094

# ---------- Ollama / LLM ----------
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3

# ---------- WhatsApp Gateway (Go) ----------
# POD_ID must be UNIQUE per gateway instance. When scaling to multiple gateway
# replicas, give each its own POD_ID (e.g. gateway-1, gateway-2).
GATEWAY_POD_ID=gateway-1
GATEWAY_PORT=8080
LOG_LEVEL=info

# ---------- Python services ----------
LOG_LEVEL_PY=INFO
LLM_BOT_PORT=8000
MANAGEMENT_API_PORT=9000

# ---------- Frontend ----------
FRONTEND_PORT=3000

# ---------- Observability ----------
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
