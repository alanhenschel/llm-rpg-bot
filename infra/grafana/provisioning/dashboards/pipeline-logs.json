{
  "id": null,
  "uid": "pipeline-logs",
  "title": "WhatsApp Pipeline Logs",
  "tags": ["pipeline", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(container)",
        "regex": "ia-pipeline_(whatsapp-gateway|llm-bot|management-api|management-frontend).*",
        "includeAll": true,
        "allValue": "ia-pipeline_(whatsapp-gateway|llm-bot|management-api).*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All pipeline logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "{container=~\"ia-pipeline_(whatsapp-gateway|llm-bot|management-api).*\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Errors only",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "{container=~\"ia-pipeline_(whatsapp-gateway|llm-bot|management-api).*\"} | json | level=`error`",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log volume by container (logs/min)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\"ia-pipeline_(whatsapp-gateway|llm-bot|management-api).*\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "WhatsApp Gateway",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "{container=~\"ia-pipeline_whatsapp-gateway.*\"} | json",
          "refId": "A"
        }
      ],
      "options": { "showLabels": false, "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending" }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "LLM Bot",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "{container=~\"ia-pipeline_llm-bot.*\"} | json",
          "refId": "A"
        }
      ],
      "options": { "showLabels": false, "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending" }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Trace — paste a trace_id to follow one conversation end-to-end",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "{container=~\"ia-pipeline_(whatsapp-gateway|llm-bot|management-api).*\"} | json | trace_id!=\"\"",
          "refId": "A"
        }
      ],
      "options": { "showLabels": true, "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending" }
    }
  ]
}
